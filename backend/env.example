# LLM API Keys
# Google AI Studio — used by both the maintenance and query agents
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model Selection
# Maintenance: needs long context + reliable tool calling
MAINTENANCE_MODEL=gemini-2.5-flash

# Query: needs to be fast and support tool use (must be a gemini-* model;
# Gemma models on the Gemini API do not support function calling)
QUERY_MODEL=gemini-2.5-flash-lite

# Data Paths
# Absolute path to the data/ directory (Docker sets this automatically)
DATA_PATH=/data

# Agent Behaviour
# Hard cap on tool-calling iterations per agent run (safety net)
MAX_AGENT_ITERATIONS=25

# Max tokens the LLM can generate in a single response
MAX_TOKENS=16384

# Temperature for maintenance agent (low = deterministic, consistent)
MAINTENANCE_TEMPERATURE=0.1

# Temperature for query agent (slightly higher = more natural answers)
QUERY_TEMPERATURE=0.4

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Logging
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
