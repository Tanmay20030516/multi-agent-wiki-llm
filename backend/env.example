# ── LLM API Keys ──────────────────────────────────────────────
# Google AI Studio — used by the maintenance agent (ingest, lint, promote)
# Get yours free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — used by the query agent (fast chat responses)
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Model Selection ───────────────────────────────────────────
# Maintenance: needs long context + reliable tool calling
MAINTENANCE_MODEL=gemini-2.5-flash-preview-05-20

# Query: needs to be fast; works on pre-structured wiki content
QUERY_MODEL=llama-3.3-70b-versatile

# Fallback if query model fails or rate-limits
QUERY_MODEL_FALLBACK=gemini-2.0-flash

# ── Data Paths ────────────────────────────────────────────────
# Absolute path to the data/ directory (Docker sets this automatically)
DATA_PATH=/data

# ── Agent Behaviour ───────────────────────────────────────────
# Hard cap on tool-calling iterations per agent run (safety net)
MAX_AGENT_ITERATIONS=25

# Max tokens the LLM can generate in a single response
MAX_TOKENS=8192

# Temperature for maintenance agent (low = deterministic, consistent)
MAINTENANCE_TEMPERATURE=0.1

# Temperature for query agent (slightly higher = more natural answers)
QUERY_TEMPERATURE=0.4

# ── Server ────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Logging ───────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
